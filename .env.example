# Anthropic API key — needed only for the AI document reader, ask-your-books, and reminders.
# The non-AI parts of the app run without a key.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: path to a folder containing your real klanten.json and api-key.txt.
# Defaults to the app folder. Real data is gitignored.
# ASESORIA_DATA_DIR=/Users/yourname/Documents/Asesoria NL
